{
	"name": "mail-frontend",
	"private": true,
	"version": "0.1.0",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"tauri": "tauri",
		"tauri:dev": "node scripts/tauri-dev-with-env.mjs",
		"tauri:dev:fresh": "node scripts/tauri-dev-fresh.mjs",
		"tauri:build": "node scripts/tauri-build.mjs",
		"tauri:build:with-sidecar": "npm run sidecar:sync:windows && npm run tauri:build",
		"tauri:smoke:startup": "node scripts/tauri-startup-smoke.mjs",
		"tauri:smoke:release-startup": "node scripts/tauri-release-startup-smoke.mjs",
		"tauri:smoke:sidecar-cors": "node scripts/tauri-sidecar-cors-smoke.mjs",
		"tauri:smoke:csp-build": "node scripts/tauri-csp-build-smoke.mjs",
		"tauri:release-config:windows": "node scripts/prepare-tauri-windows-release-config.mjs",
		"tauri:generate-latest:windows": "node scripts/generate-tauri-latest-windows.mjs",
		"tauri:signing-config:windows": "node scripts/prepare-tauri-windows-signing-config.mjs",
		"tauri:updater-config": "node scripts/prepare-tauri-updater-config.mjs",
		"sidecar:sync:windows": "node scripts/sync-backend-sidecar-windows.mjs",
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"preview:test": "node scripts/playwright-preview.mjs",
		"prepare": "svelte-kit sync",
		"check": "npm run check:csp && npm run check:typography && npm run check:versions && npm run check:docs && npm run check:api && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:csp": "node scripts/check-csp-parity.mjs",
		"check:docs": "node scripts/check-doc-claims.mjs",
		"check:typography": "node scripts/check-typography.mjs",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"check:versions": "node scripts/check-version-sync.mjs",
		"bump:version": "node scripts/bump-version.mjs",
		"check:i18n": "node scripts/check-i18n-keys.mjs",
		"check:i18n:backend": "node scripts/check-backend-i18n-keys.mjs",
		"check:translations": "node scripts/check-translation-whitelist.mjs",
		"check:translations:strict": "node scripts/check-translation-whitelist.mjs --mode=strict",
		"check:api": "node scripts/check-api-schema.mjs",
		"generate:api": "node scripts/generate-api.mjs --snapshot",
		"generate:api:live": "node scripts/generate-api.mjs",
		"generate:api:snapshot": "node scripts/generate-api.mjs --snapshot",
		"regen:licenses": "node scripts/regen-third-party-licenses.mjs",
		"regen:licenses:backend": "node ../backend/scripts/regen-third-party-licenses.mjs",
		"regen:licenses:tauri": "node src-tauri/scripts/regen-third-party-licenses.mjs",
		"regen:licenses:all": "npm run regen:licenses && npm run regen:licenses:backend && npm run regen:licenses:tauri && npm run regen:sbom:all && npm run regen:notice",
		"regen:notice": "node scripts/generate-bundled-notice.mjs",
		"regen:sbom": "node scripts/generate-sbom.mjs",
		"regen:sbom:backend": "node ../backend/scripts/generate-sbom.mjs",
		"regen:sbom:tauri": "node src-tauri/scripts/generate-sbom.mjs",
		"regen:sbom:all": "npm run regen:sbom && npm run regen:sbom:backend && npm run regen:sbom:tauri",
		"check:sbom": "node scripts/validate-sbom.mjs",
		"lint": "prettier --check . && eslint . && npm run check:i18n",
		"knip": "knip --no-progress",
		"format": "prettier --write .",
		"test:e2e:stable": "node scripts/run-playwright-with-preview.mjs",
		"test:functional:stable": "node scripts/run-playwright-with-preview.mjs --project=functional",
		"test:performance:stable": "node scripts/run-playwright-with-preview.mjs src/routes/performance.functional.e2e.ts",
		"test:a11y:stable": "node scripts/run-playwright-with-preview.mjs src/routes/a11y.e2e.ts",
		"test:e2e": "node scripts/run-e2e-stable.mjs",
		"test:a11y": "node scripts/run-playwright-with-preview.mjs src/routes/a11y.e2e.ts",
		"test:unit": "vitest run",
		"test:unit:coverage": "vitest run --coverage",
		"test:unit:watch": "vitest",
		"test": "npm run test:unit && npm run test:e2e"
	},
	"engines": {
		"node": ">=26"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.12.1",
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.61.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.68.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tauri-apps/cli": "^2.11.4",
		"@vitest/coverage-v8": "^4.1.6",
		"@vitest/ui": "^4.1.9",
		"eslint": "^10.6.0",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.7.0",
		"jsdom": "^29.1.1",
		"knip": "^6.26.0",
		"msw": "^2.14.3",
		"openapi-typescript": "^7.13.0",
		"prettier": "^3.9.4",
		"prettier-plugin-svelte": "^4.1.1",
		"svelte": "^5.56.4",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.1",
		"vite": "^8.0.10",
		"vitest": "^4.1.6"
	},
	"dependencies": {
		"@internationalized/date": "^3.12.1",
		"@tailwindcss/vite": "^4.2.4",
		"@tauri-apps/api": "^2.11.1",
		"@tauri-apps/plugin-fs": "^2.5.1",
		"@tauri-apps/plugin-http": "^2.5.8",
		"@tauri-apps/plugin-shell": "^2.3.5",
		"bits-ui": "^2.17.3",
		"clsx": "^2.1.1",
		"svelte-i18n": "^4.0.1",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.1",
		"tw-animate-css": "^1.4.0"
	},
	"overrides": {
		"@sveltejs/kit": {
			"cookie": "0.7.2"
		},
		"postcss": "8.5.12",
		"esbuild": "0.28.1",
		"undici": "7.28.0",
		"js-yaml": "4.2.0",
		"openapi-typescript": {
			"typescript": "$typescript"
		}
	},
	"msw": {
		"workerDirectory": [
			"static"
		]
	}
}
