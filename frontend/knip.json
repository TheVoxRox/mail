{
	"$schema": "https://unpkg.com/knip@5/schema.json",
	"entry": [
		"src/routes/**/+{page,layout,server,error}.{svelte,ts,js}",
		"src/app.html",
		"src/lib/api/type-contract.ts",
		"src/routes/**/*.e2e.ts",
		"src/test-fixtures/msw/worker.ts",
		"scripts/**/*.{mjs,ts,js}",
		"playwright.existing-server.config.ts"
	],
	"project": ["src/**/*.{ts,svelte}", "scripts/**/*.{mjs,ts,js}"],
	"ignore": ["src/lib/api/generated.ts", "src/test-stubs/**"],
	"ignoreDependencies": ["openapi-typescript", "tw-animate-css"],
	"ignoreExportsUsedInFile": true
}
