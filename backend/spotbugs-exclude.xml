<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter
    xmlns="https://github.com/spotbugs/filter/3.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0 https://raw.githubusercontent.com/spotbugs/spotbugs/master/spotbugs/etc/findbugsfilter.xsd">

    <!-- EI_EXPOSE_REP/2 false-positives:
         - JPA entities and DTOs must have getters/setters that return references.
         - Spring DI (constructor injection) inherently produces EI_EXPOSE_REP2,
           because every `this.x = x` stores a reference to the injected bean.
         These warnings are not actionable for a Spring project. -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>

    <!-- Spring CGLIB generated proxy classes ($$SpringCGLIB$$N suffix):
         - EI_EXPOSE_STATIC_REP2: CGLIB$SET_STATIC_CALLBACKS stores Callback[]
           in a static field — internal CGLIB detail, not applicable to our code.
         - CT_CONSTRUCTOR_THROW: proxy constructor delegating to the original
           bean may throw — again CGLIB internals.
         These bugs live in generated code, not in our classes. -->
    <Match>
        <Class name="~.*\$\$SpringCGLIB\$\$.*"/>
    </Match>

    <!-- CT_CONSTRUCTOR_THROW on JPA entities (SpotBugs 4.10+ raised this detector's
         reach): the "finalizer attack" it guards against requires a non-final,
         finalizable class, but Hibernate forbids making @Entity classes final
         (it subclasses them for lazy proxies). A validating constructor that
         throws is the idiomatic JPA pattern, so the only "fix" — marking the
         class final — is not available to us. Suppress for entities. -->
    <Match>
        <Bug pattern="CT_CONSTRUCTOR_THROW"/>
        <Class name="~org\.voxrox\.mailbackend\..*\.entity\..*"/>
    </Match>
</FindBugsFilter>
