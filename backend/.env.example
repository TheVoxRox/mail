# ==============================================================================
# Template for the local .env. Copy as .env and fill in real values.
#   cp .env.example .env
# .env is in .gitignore; .env.example is committed.
# ==============================================================================

# --- Crypto (AES-256-GCM key derivation) ---
# Optional local dev override. If you leave the values empty, the backend will
# automatically generate ${app.data-dir}/crypto.bin on first start.
# Generate with:
#   openssl rand -base64 48   # MAIL_CRYPTO_KEY (min. 32 chars)
#   openssl rand -hex 32      # MAIL_CRYPTO_SALT
MAIL_CRYPTO_KEY=
MAIL_CRYPTO_SALT=

# --- Google OAuth2 ---
# Generate in Google Cloud Console -> APIs & Services -> Credentials -> OAuth
# client ID for a desktop/native application with a loopback redirect. The
# backend runs on a random port, so the redirect is built at runtime as:
# http://127.0.0.1:<runtime-port>/login/oauth2/code/google
# Do not use a Web client restricted to a single fixed port unless you also
# explicitly override `server.port` to the same value.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Microsoft OAuth2 (Outlook.com / Exchange Online) ---
# Registered as a PUBLIC client (RFC 8252): no client secret is used — the flow
# is secured by PKCE. Generate in Microsoft Entra ID -> App registrations ->
# New registration:
#   - Supported account types: "Accounts in any organizational directory and
#     personal Microsoft accounts" (multi-tenant + MSA, tenant 'common').
#   - Authentication -> "Allow public client flows" = Yes.
#   - Authentication -> Add a platform -> "Mobile and desktop applications",
#     loopback redirect (Microsoft substitutes the random local port at runtime):
#     http://localhost/login/oauth2/code/microsoft
#     (register without a port; the backend derives it from the Host header.)
#   - API permissions (delegated):
#       openid, email, profile, offline_access,
#       https://outlook.office.com/IMAP.AccessAsUser.All,
#       https://outlook.office.com/SMTP.Send
# A client secret is NOT required and is not sent (client-authentication-method=
# none). Leave it empty if you do not use Outlook/Exchange — the backend has
# local placeholder fallbacks and starts without it; the real OAuth flow needs
# only a real client ID.
MICROSOFT_OAUTH_CLIENT_ID=
