<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Spring Boot defaults: console + main rolling file patterns remain
         untouched. On top of them this file (a) rebinds the message words to a
         CR/LF-stripping converter (log-injection guard, below) and (b) adds a
         dedicated appender for the AUDIT logger. -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- CWE-117 log-injection guard: rebind the message words to a converter that
         strips CR/LF before the line is written, so externally-influenced values
         (IMAP folder names, request URIs, UIDs, exception/validation text, ...)
         cannot forge log entries. Declared before the appender includes below so
         the rule is registered before their encoders compile their patterns. -->
    <conversionRule conversionWord="m" class="org.voxrox.mailbackend.util.CrlfSafeMessageConverter"/>
    <conversionRule conversionWord="msg" class="org.voxrox.mailbackend.util.CrlfSafeMessageConverter"/>
    <conversionRule conversionWord="message" class="org.voxrox.mailbackend.util.CrlfSafeMessageConverter"/>

    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>
    <include resource="org/springframework/boot/logging/logback/file-appender.xml"/>

    <springProperty scope="context" name="dataDir" source="app.data-dir"/>

    <!-- ============================================================
         AUDIT appender — append-only record of security events.
         Longer retention (1 year) than the main log (7 days).
         ============================================================ -->
    <appender name="AUDIT_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${dataDir}/logs/audit.log</file>
        <append>true</append>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${dataDir}/logs/audit.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>365</maxHistory>
            <totalSizeCap>500MB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- The AUDIT logger is isolated — additivity=false prevents duplication into the main log. -->
    <logger name="AUDIT" level="INFO" additivity="false">
        <appender-ref ref="AUDIT_FILE"/>
    </logger>

    <!-- Main application logger (Spring Boot defaults). -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

</configuration>
